    <source src="her.mp3" type="audio/mpeg">
</audiofunction showLovePage(){

    document.getElementById("questionPage").classList.add("hidden");
    document.getElementById("lovePage").classList.remove("hidden");

    // Confetti explosion
    confetti({
        particleCount: 250,
        spread: 180,
        origin: { y: 0.6 }
    });

    // Play music
    const music = document.getElementById("bgMusic");
    if(music){
        music.play();
    }

    const text =
    "Fidhuuu ❤️<br><br>" +
    "You are the love of my life. 💖<br><br>" +
    "You are the reason I smile every day and feel happy about myself. 🌹✨<br><br>" +
    "I will love you till eternity and forever. ❤️♾️💕<br><br>" +
    "💞🥰🌹❤️✨💖💕<br><br>" +
    "Yours,<br><b>Dev ❤️</b>";

    let i = 0;

    function typeWriter(){
        if(i < text.length){
            document.getElementById("typewriter").innerHTML += text.charAt(i);
            i++;
            setTimeout(typeWriter, 35);
        }
    }

    typeWriter();
}